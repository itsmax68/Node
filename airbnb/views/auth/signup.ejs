<%- include('../partials/head') %>
  </head>

  <body class="bg-gray-50 min-h-screen bg-[url('https://images.unsplash.com/photo-1501785888041-af3ef285b470?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80')] bg-cover bg-center bg-fixed">
    <div class="min-h-screen backdrop-blur-sm bg-black/20">
      <%- include('../partials/nav') %>
      <div class="flex items-center justify-center pt-16 pb-20 px-4 sm:px-6 lg:px-8">
        <main class="w-full max-w-md p-8 sm:p-10 bg-white/90 backdrop-blur-xl rounded-3xl shadow-2xl border border-white/50 transform transition-all duration-300 hover:shadow-rose-500/10">
          <div class="mb-8 text-center">
            <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 mb-2">
              Join Airbnb
            </h1>
            <p class="text-sm text-gray-600">Discover incredible places to stay and host.</p>
          </div>
          <form action="/signup" method="POST" class="space-y-5">
            <% if(typeof errors !=='undefined' && errors.length > 0) { %>
              <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-4 rounded-r-xl shadow-sm w-full">
                <div class="flex">
                  <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">There were errors with your submission</h3>
                    <div class="mt-2 text-sm text-red-700">
                      <ul class="list-disc pl-5 space-y-1">
                        <% errors.forEach(err => { %>
                          <li><%= err.msg %></li>
                        <% }) %>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
            <% } %>
            
            <div class="flex gap-4">
              <input type="text" name="firstName" placeholder="First Name" required
                class="w-1/2 px-5 py-3 border border-gray-200 rounded-xl bg-white/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm placeholder-gray-400" />
              <input type="text" name="lastName" placeholder="Last Name" required
                class="w-1/2 px-5 py-3 border border-gray-200 rounded-xl bg-white/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm placeholder-gray-400" />
            </div>

            <input type="email" name="email" placeholder="Email address" required
              class="w-full px-5 py-3 border border-gray-200 rounded-xl bg-white/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm placeholder-gray-400" />
              
            <input type="password" name="password" placeholder="Password" required
              class="w-full px-5 py-3 border border-gray-200 rounded-xl bg-white/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm placeholder-gray-400" />
              
            <input type="password" name="confirmPassword" placeholder="Confirm Password" required
              class="w-full px-5 py-3 border border-gray-200 rounded-xl bg-white/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm placeholder-gray-400" />

            <div class="relative">
              <select name="userType" required class="w-full px-5 py-3 border border-gray-200 rounded-xl bg-white/50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm appearance-none text-gray-700 cursor-pointer">
                <option value="" disabled selected>I want to be a...</option>
                <option value="guest">Guest</option>
                <option value="host">Host</option>
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-gray-500">
                <svg class="h-4 w-4 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"/></svg>
              </div>
            </div>

            <div class="flex items-center mt-6 mb-2">
              <input type="checkbox" name="terms" id="terms" required class="h-4 w-4 text-rose-500 focus:ring-rose-500 border-gray-300 rounded cursor-pointer transition-colors" />
              <label for="terms" class="ml-3 block text-sm text-gray-600 cursor-pointer select-none">
                I agree to the <a href="#" class="font-medium text-rose-600 hover:text-rose-500 hover:underline">Terms & Conditions</a>
              </label>
            </div>

            <button type="submit" class="w-full flex justify-center py-3.5 px-4 border border-transparent rounded-xl shadow-lg text-sm font-bold text-white bg-gradient-to-r from-rose-500 to-red-600 hover:from-rose-600 hover:to-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-rose-500 transform transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0">
              Create Account
            </button>
            
            <p class="mt-6 text-center text-sm text-gray-600">
              Already have an account? 
              <a href="/login" class="font-medium text-rose-600 hover:text-rose-500 hover:underline transition-colors">Log in</a>
            </p>
          </form>
        </main>
      </div>
    </div>
  </body>

  </html>