<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50 min-h-screen text-gray-800">
      <%- include('../partials/nav') %>
      <main class="container mx-auto px-6 py-10 max-w-7xl">
          
          <div class="mb-6">
            <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-2">
                <%= home.houseName %>
            </h1>
            <div class="flex items-center text-sm text-gray-600 font-medium space-x-4">
              <div class="flex items-center gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-rose-500">
                  <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                </svg>
                <span class="text-gray-900 font-bold"><%= home.rating %></span> <span class="underline">reviews</span>
              </div>
              <span class="text-gray-300">•</span>
              <div class="flex items-center gap-1 underline">
                <%= home.location %>
              </div>
            </div>
          </div>

          <!-- Hero Image -->
          <div class="w-full h-[50vh] min-h-[400px] rounded-3xl overflow-hidden mb-12 shadow-sm">
              <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>" class="w-full h-full object-cover transition-transform duration-1000 hover:scale-105">
          </div>
          
          <div class="flex flex-col lg:flex-row gap-12">
              <!-- Left Content: Description & Details -->
              <div class="lg:w-2/3 space-y-10">
                  <div class="pb-8 border-b border-gray-200">
                      <h2 class="text-2xl font-bold mb-4 text-gray-900">About this space</h2>
                      <p class="text-gray-600 leading-relaxed text-lg"><%= home.description %></p>
                  </div>
              </div>

              <!-- Right Content: Floating Booking Card -->
              <div class="lg:w-1/3">
                <div class="sticky top-32 bg-white rounded-3xl shadow-xl border border-gray-100 p-6 sm:p-8">
                  <div class="flex items-end justify-between mb-6">
                    <div>
                      <span class="text-3xl font-extrabold text-gray-900">Rs<%= home.price %></span>
                      <span class="text-gray-500 font-medium"> / night</span>
                    </div>
                  </div>
                  
                  <div class="space-y-4 mb-6">
                    <button class="w-full flex justify-center py-4 px-4 border border-transparent rounded-xl shadow-md text-base font-bold text-white bg-gradient-to-r from-rose-500 to-red-600 hover:from-rose-600 hover:to-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-rose-500 transform transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0">
                      Reserve Now
                    </button>
                    <div class="w-full flex justify-center">
                      <%- include('../partials/favourite', {home: home}) %>
                    </div>
                  </div>

                  <p class="text-center text-gray-500 text-sm">You won't be charged yet</p>
                </div>
              </div>
          </div>
      </main>
  </body>
</html>