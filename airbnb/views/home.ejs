<%- include('partials/head') %>
</head>
<body class="bg-[#f5f5f5] min-h-screen font-sans">

  <%- include('partials/nav') %>

    <main class="flex justify-center mt-12 px-4">
      <div class="bg-white py-12 px-8 shadow-[0_4px_8px_rgba(0,0,0,0.1)] rounded-lg w-full max-w-[600px]">
        
        <h1 class="text-[#333333] text-3xl font-bold tracking-tight text-center mb-8 pb-4 border-b border-gray-100">
          Here are our registered homes
        </h1>
  
        <% if (registeredHomes && registeredHomes.length > 0) { %>
          <ul class="space-y-3 text-left">
            <% registeredHomes.forEach(home => { %>
              <li class="bg-gray-50 border border-gray-200 rounded-lg px-5 py-4 text-gray-700 font-medium shadow-sm hover:border-gray-300 transition-colors flex items-center justify-between">
                <span class="truncate"><%= home.HouseName %></span>
                <span class="text-xs bg-red-50 text-[#ff5a5f] font-semibold px-2.5 py-1 rounded-full uppercase tracking-wider">Active</span>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <div class="text-center py-6">
            <p class="text-gray-400 mb-4">No homes registered yet.</p>
            <a href="/host/add-home" class="inline-block bg-[#ff5a5f] text-white font-semibold px-4 py-2 rounded text-sm hover:bg-[#e54e52] transition-colors">
              Add the First Home
            </a>
          </div>
        <% } %>

      </div>
    </main>

</body>
</html>