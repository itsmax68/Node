<%- include('../partials/head') %>
  </head>

  <body class="bg-gray-50 min-h-screen text-gray-800">
    <%- include('../partials/nav') %>
      <main class="container mx-auto px-6 py-12 max-w-2xl">
        <div class="bg-white rounded-3xl shadow-xl border border-gray-100 p-8 sm:p-12 transform transition-all">
          <div class="mb-8 text-center">
            <h1 class="text-3xl font-extrabold tracking-tight text-gray-900 mb-2">
              Register Your Home
            </h1>
            <p class="text-gray-500 text-sm">Fill in the details to list your property on Airbnb.</p>
          </div>
          
          <form action="/host/add-home" method="POST" class="space-y-5">
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Property Name</label>
                <input type="text" name="houseName" placeholder="e.g. Cozy Cabin in the Woods" required
                  class="w-full px-5 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm" />
              </div>

              <div class="flex gap-4">
                <div class="flex-1">
                  <label class="block text-sm font-medium text-gray-700 mb-1">Price per night (Rs)</label>
                  <input type="number" name="price" placeholder="e.g. 5000" required
                    class="w-full px-5 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm" />
                </div>
                <div class="flex-1">
                  <label class="block text-sm font-medium text-gray-700 mb-1">Rating</label>
                  <input type="text" name="rating" placeholder="e.g. 4.8" required
                    class="w-full px-5 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm" />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Location</label>
                <input type="text" name="location" placeholder="e.g. Manali, Himachal Pradesh" required
                  class="w-full px-5 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm" />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Photo URL</label>
                <input type="url" name="photoUrl" placeholder="https://..." required
                  class="w-full px-5 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea name="description" placeholder="Describe your property..." rows="4" required
                  class="w-full px-5 py-3 border border-gray-200 rounded-xl bg-gray-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all shadow-sm resize-none"></textarea>
              </div>
            </div>

            <button type="submit" class="w-full flex justify-center py-4 px-4 mt-6 border border-transparent rounded-xl shadow-lg text-base font-bold text-white bg-gradient-to-r from-rose-500 to-red-600 hover:from-rose-600 hover:to-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-rose-500 transform transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0">
              List Property
            </button>
          </form>
        </div>
      </main>
  </body>
</html>