<%- include('../partials/head') %>
</head>
<body class="bg-[#f5f5f5] min-h-screen font-sans">

  <%- include('../partials/nav') %>

    <!-- Main Content Area -->
    <main class="flex justify-center mt-12 px-4">
      <div class="bg-white text-center py-12 px-12 shadow-[0_4px_8px_rgba(0,0,0,0.1)] rounded-lg w-full max-w-[600px]">
        
        <h2 class="text-[#333333] text-3xl font-bold mb-6">Register Your Home on AirBnB</h2>
        
        <form action="/host/add-home" method="POST" class="space-y-4">
          <input 
            type="text" 
            name="HouseName" 
            placeholder="Enter your House Name" 
            class="w-full px-4 py-3 border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-gray-400 placeholder-gray-400 text-gray-700"
          >

            <input 
              type="text" 
              name="price" 
              placeholder="Price per night" 
              class="w-full px-4 py-3 border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-gray-400 placeholder-gray-400 text-gray-700"
            >

              <input 
              type="text" 
              name="location" 
              placeholder="Location" 
              class="w-full px-4 py-3 border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-gray-400 placeholder-gray-400 text-gray-700"
            >

              <input 
              type="text" 
              name="rating" 
              placeholder="Rating" 
              class="w-full px-4 py-3 border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-gray-400 placeholder-gray-400 text-gray-700"
            >

              <input 
              type="text" 
              name="photo" 
              placeholder="Enter photo url" 
              class="w-full px-4 py-3 border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-gray-400 placeholder-gray-400 text-gray-700"
            >

          <button 
            type="submit" 
            class="w-full bg-[#ff5a5f] text-white font-semibold py-3 rounded hover:bg-[#e54e52] transition-colors"
          >
            Submit
          </button>
        </form>

      </div>
    </main>

</body>
</html>