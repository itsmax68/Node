<%- include('../partials/head') %>
  </head>
  <body class="bg-gray-50 min-h-screen text-gray-800">
    <%- include('../partials/nav') %>
    <main class="container mx-auto px-6 py-12 max-w-7xl">
      <div class="flex flex-col md:flex-row items-center justify-between mb-8 gap-4">
        <div>
          <h2 class="text-3xl font-extrabold tracking-tight text-gray-900">
            Host Dashboard
          </h2>
          <p class="text-gray-500 mt-1">Manage your registered properties.</p>
        </div>
        <a href="/host/add-home" class="inline-flex items-center px-5 py-2.5 bg-gray-900 text-white hover:bg-rose-500 rounded-full font-semibold transition-colors duration-300 shadow-sm">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          Add New Home
        </a>
      </div>

      <% if (registeredHomes.length === 0) { %>
        <div class="text-center py-20 bg-white rounded-3xl shadow-sm border border-gray-100">
          <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          <h3 class="mt-2 text-sm font-medium text-gray-900">No properties</h3>
          <p class="mt-1 text-sm text-gray-500">Get started by registering your first home.</p>
          <div class="mt-6">
            <a href="/host/add-home" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-full text-white bg-rose-500 hover:bg-rose-600">
              Register Home
            </a>
          </div>
        </div>
      <% } else { %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
          <% registeredHomes.forEach(home => { %>
            <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100 flex flex-col">
              <div class="relative w-full aspect-[4/3] overflow-hidden">
                <img src="<%= home.photoUrl %>" alt="<%= home.houseName %>" class="w-full h-full object-cover">
                <div class="absolute top-4 right-4 bg-white/90 backdrop-blur-sm px-2.5 py-1 rounded-full text-xs font-bold text-gray-700 shadow-sm flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-rose-500">
                    <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
                  </svg>
                  <%= home.rating %>
                </div>
              </div>
              
              <div class="p-5 flex flex-col flex-grow">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="text-lg font-bold text-gray-900 truncate pr-4"><%= home.houseName %></h3>
                </div>
                <p class="text-sm text-gray-500 mb-4 flex items-center">
                  <svg class="w-4 h-4 mr-1 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  <%= home.location %>
                </p>
                
                <div class="mt-auto pt-4 border-t border-gray-100 space-y-3">
                  <div class="flex flex-col">
                    <span class="text-sm text-gray-500">Price</span>
                    <span class="text-lg font-extrabold text-gray-900">Rs<%= home.price %><span class="text-sm font-normal text-gray-500"> / night</span></span>
                  </div>
                  
                  <div class="flex items-center gap-2 pt-2">
                    <a href="/host/edit-home/<%=home._id%>?editing=true" class="flex-1 text-center px-4 py-2 bg-gray-100 text-gray-700 hover:bg-gray-200 text-sm font-semibold rounded-xl transition-colors duration-300">
                      Edit
                    </a>
                    <form action="/host/delete-home/<%= home._id %>" method="POST" class="flex-1 m-0">
                      <button type="submit" class="w-full px-4 py-2 bg-red-50 text-red-600 hover:bg-red-100 text-sm font-semibold rounded-xl transition-colors duration-300">
                        Delete
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </main>
  </body>
</html>